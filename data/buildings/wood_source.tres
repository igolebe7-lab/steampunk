[gd_resource type="Resource" script_class="BuildingDef" load_steps=3 format=3]

[ext_resource type="Script" path="res://src/simulation/definitions/building_def.gd" id="1"]
[ext_resource type="Script" path="res://src/simulation/definitions/logistics_port_def.gd" id="2_port"]

[sub_resource type="Resource" id="LogisticsPort_wood_output"]
script = ExtResource("2_port")
direction = &"output"
resource_id = &"wood"
accepted_building_roles = Array[StringName]([&"main_warehouse", &"transfer_depot"])

[resource]
script = ExtResource("1")
id = &"wood_source"
display_name_key = &"building.wood_source.name"
footprint = Array[Vector2i]([Vector2i(0, 0)])
inventory_capacity = 8
source_resource_id = &"wood"
source_interval_ticks = 10
source_capacity = 8
role = &"source"
max_level = 3
outgoing_worker_slots_by_level = Array[int]([2, 3, 4])
logistics_ports = Array[ExtResource("2_port")]([SubResource("LogisticsPort_wood_output")])
